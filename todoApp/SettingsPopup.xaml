<Window x:Class="todoApp.SettingsPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="260" Height="320"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent">

    <Border x:Name="RootBorder"
            CornerRadius="16"
            Background="#1F1F1F"
            BorderBrush="#444444"
            BorderThickness="1">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <TextBlock x:Name="HeaderText"
                           Text="Settings"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <Button x:Name="CloseBtn"
                        Content="✕"
                        FontSize="12"
                        Width="28" Height="28"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        Foreground="#AAAAAA"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CloseBtn_Click"/>
            </Grid>

            <!-- Divider -->
            <Border x:Name="Divider1" Grid.Row="1" Height="1" Background="#333333" VerticalAlignment="Center"/>

            <!-- Profile Info -->
            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Border x:Name="ProfileCircle" Width="44" Height="44" CornerRadius="22" Margin="0,0,12,0">
                    <TextBlock x:Name="ProfileInitialsText"
                               FontSize="16" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="ProfileNameText" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="ProfileSubText" Text="Personal Profile" FontSize="11" Foreground="#AAAAAA" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Divider -->
            <Border x:Name="Divider2" Grid.Row="3" Height="1" Background="#333333" VerticalAlignment="Center"/>

            <!-- Theme Toggle -->
            <Grid Grid.Row="4">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="ThemeLabelText" FontSize="13" FontWeight="Bold" Foreground="White" Text="Theme"/>
                    <TextBlock x:Name="ThemeSubText" FontSize="11" Foreground="#AAAAAA" Margin="0,2,0,0" Text="Currently Dark"/>
                </StackPanel>
                <Border x:Name="ToggleTrack"
                        Width="44" Height="24"
                        CornerRadius="12"
                        Background="#E50914"
                        HorizontalAlignment="Right"
                        Cursor="Hand"
                        MouseLeftButtonUp="ThemeToggle_Click">
                    <Ellipse x:Name="ToggleThumb" Width="18" Height="18" Fill="White"
                             HorizontalAlignment="Right" Margin="0,0,3,0"/>
                </Border>
            </Grid>

            <!-- Divider -->
            <Border x:Name="Divider3" Grid.Row="5" Height="1" Background="#333333" VerticalAlignment="Center"/>

            <!-- Delete Profile -->
            <Button Grid.Row="6"
                    x:Name="DeleteProfileBtn"
                    Content="🗑 Delete Profile"
                    FontSize="13"
                    Height="36"
                    Foreground="#FF4444"
                    BorderThickness="1"
                    Cursor="Hand"
                    Click="DeleteProfileBtn_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#2A2A2A"/>
                        <Setter Property="BorderBrush" Value="#444444"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="DeleteBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A2020"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>
