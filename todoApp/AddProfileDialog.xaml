<Window x:Class="todoApp.AddProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Profile"
        Height="200" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#141414">

    <StackPanel VerticalAlignment="Center" Margin="32,0">

        <TextBlock Text="Enter a profile name"
                   Foreground="White"
                   FontSize="16"
                   Margin="0,0,0,12"/>

        <TextBox x:Name="NameInput"
                 FontSize="14"
                 Padding="8"
                 Background="#2A2A2A"
                 Foreground="White"
                 BorderBrush="#444444"
                 CaretBrush="White"
                 Margin="0,0,0,16"/>

        <Button Content="Create Profile"
                FontSize="14"
                Padding="0,8"
                Background="#E50914"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="Create_Click"/>
    </StackPanel>
</Window>
