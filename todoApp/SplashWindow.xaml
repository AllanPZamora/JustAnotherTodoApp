<Window x:Class="todoApp.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        Width="800" Height="450"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/clipboard.ico"
        ShowInTaskbar="False">

    <Border CornerRadius="20" Background="#1F1F1F" Padding="20">
        <Grid>

            <!-- Gradient Background -->
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#141414" Offset="0"/>
                    <GradientStop Color="#1F1F1F" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Content -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">

                <!-- Scale animation target -->
                <StackPanel.RenderTransform>
                    <ScaleTransform x:Name="LogoScale" ScaleX="0.8" ScaleY="0.8"/>
                </StackPanel.RenderTransform>

                <!-- Logo -->
                <Grid HorizontalAlignment="Center">
                    <!-- Glow -->
                    <Ellipse Width="100" Height="100" Opacity="0.2"
                             Fill="#E50914"/>

                    <!-- Main Circle -->
                    <Ellipse Width="80" Height="80" Fill="#E50914">
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="20"
                                              ShadowDepth="0"
                                              Color="#E50914"/>
                        </Ellipse.Effect>
                    </Ellipse>

                    <!-- Check -->
                    <TextBlock Text="✓"
                               FontSize="40"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Title -->
                <TextBlock Text="To Do Calendar"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,25,0,0"/>

                <!-- Subtitle -->
                <TextBlock Text="Plan your day, every day."
                           FontSize="14"
                           Foreground="#AAAAAA"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>

                <!-- Loading -->
                <TextBlock x:Name="LoadingText"
                           Text="Loading..."
                           FontSize="12"
                           Foreground="#666"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"/>

            </StackPanel>
        </Grid>
    </Border>
</Window>